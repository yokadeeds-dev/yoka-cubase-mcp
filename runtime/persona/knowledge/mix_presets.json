      "plugins": {
        "fabfilter_pro_q3": {
          "bands": [
            {"num": 1, "freq_hz": 30, "gain_db": 0, "q": 1.0, "shape": "Low Cut", "slope": 24, "enabled": true},
            {"num": 2, "freq_hz": 250, "gain_db": -2, "q": 1.0, "shape": "Bell", "enabled": true},
