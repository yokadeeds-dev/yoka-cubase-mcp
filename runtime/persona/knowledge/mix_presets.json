        "fabfilter_pro_c2": {
          "threshold_db": -15,
          "ratio": 3.0,
          "attack_ms": 10,
          "release_ms": 100,
          "knee_db": 6,
          "wet_gain_db": 0,
          "dry_gain_db": -36
        }
      }
    },

