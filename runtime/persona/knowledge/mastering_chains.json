    },
    "club_dj": {
      "display_name": "Club / DJ-Set",
      "target_lufs_integrated": -8,
      "true_peak_db": -0.3,
      "normalization": "none",
      "notes": "Maximale Lautheit für Sound-System-Wiedergabe. DJ-Mixer hat eigene Headroom-Strategie."
    },
    "vinyl": {
      "display_name": "Vinyl",
      "target_lufs_integrated": null,
      "true_peak_db": -3,
      "normalization": "physical",
      "notes": "LUFS irrelevant; Peak-Kontrolle und Mono-Bass kritisch. Cutting-Engineer macht finale Anpassungen."
