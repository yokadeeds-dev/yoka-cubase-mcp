  "generic_chain": [
    {
      "step_id": "high_pass",
      "order": 1,
      "display_name": "High-Pass Filter",
      "type": "eq",
      "params": {
        "cutoff_hz": 30,
        "slope_db_oct": 24
      },
      "purpose": "Subsonic-Rumpeln entfernen, Headroom sparen.",
      "optional": false
    },
    {
      "step_id": "corrective_eq",
      "order": 2,
      "display_name": "Korrigierender EQ",
      "type": "eq",
      "params": {
        "approach": "subtractive",
        "q_factor_range": [0.5, 1.0],
        "linear_phase": false,
        "typical_moves": [
          { "freq_hz": 250, "gain_db": -1, "purpose": "Boxiness reduzieren" },
          { "freq_hz": 3000, "gain_db": 0.5, "purpose": "Präsenz" },
          { "freq_hz": 8000, "gain_db": -1, "purpose": "Harshness zähmen" }
        ]
      },
      "purpose": "Probleme beheben, nicht kreativ gestalten.",
      "optional": false
    },
    {
      "step_id": "compressor",
      "order": 3,
      "display_name": "Master-Kompressor (Glue)",
      "type": "compressor",
      "params": {
        "ratio_range": [1.5, 2.0],
        "attack_ms_range": [30, 50],
        "release_ms_range": [200, 400],
        "release_auto": true,
        "gain_reduction_db_max": 2,
        "knee": "soft"
      },
      "purpose": "Subtle 'Klebstoff' zwischen Elementen, kein Pumpen.",
      "optional": true,
      "default_enabled": true
    },
    {
      "step_id": "saturation",
      "order": 4,
      "display_name": "Saturation / Tape",
      "type": "saturation",
      "params": {
        "drive_pct_range": [10, 20],
        "tape_speed_ips": 15,
        "type_options": ["tape", "tube", "transformer"]
      },
      "purpose": "Harmonische Anreicherung, Wärme, analoger Charakter.",
      "optional": true,
      "default_enabled": true
    },
    {
      "step_id": "creative_eq",
      "order": 5,
      "display_name": "Kreativer EQ",
      "type": "eq",
      "params": {
        "approach": "additive",
        "shelving_moves": [
          { "freq_hz": 12000, "gain_db": 1, "filter_type": "high_shelf", "purpose": "Air, Luftigkeit" },
          { "freq_hz": 100, "gain_db": 0.5, "filter_type": "low_shelf", "purpose": "Bass-Wärme" }
        ]
      },
      "purpose": "Tonale Charakter-Akzente.",
      "optional": true,
      "default_enabled": true
    },
    {
      "step_id": "multiband_compressor",
      "order": 6,
      "display_name": "Multiband-Kompressor",
      "type": "multiband_compressor",
      "params": {
        "bands": [
          { "name": "bass", "range_hz": [20, 120], "ratio": "2:1", "threshold_db": -15 },
          { "name": "mids", "range_hz": [120, 5000], "ratio": "1.5:1" },
          { "name": "highs", "range_hz": [5000, 20000], "ratio": "2:1", "purpose": "Harshness zähmen" }
        ]
      },
      "purpose": "Frequenzbereich-spezifische Dynamik-Kontrolle.",
      "optional": true,
      "default_enabled": false,
      "warning": "Auf Ambient/Klassik vorsichtig — kann atmosphärische Dichte zerstören."
    },
    {
      "step_id": "stereo_widener",
      "order": 7,
      "display_name": "Stereo-Imager",
      "type": "stereo",
      "params": {
        "width_pct": 110,
        "preserve_mono_below_hz": 150,
        "stereo_above_hz": 200
      },
      "purpose": "Stereo-Breite oberhalb Bass; Bass bleibt mono für Phasentreue.",
      "optional": true,
      "default_enabled": false,
      "warning": "Mono-Kompatibilität immer prüfen — Phasen-Auslöschung möglich."
    },
    {
      "step_id": "limiter",
      "order": 8,
      "display_name": "Brick-Wall Limiter",
      "type": "limiter",
      "params": {
        "ceiling_db": -1,
        "release": "auto",
        "oversampling_factor": 4,
        "true_peak_aware": true
      },
      "purpose": "Endgültige Lautheit + True-Peak-Kontrolle.",
      "optional": false
    },
    {
      "step_id": "metering",
      "order": 9,
      "display_name": "Metering & Verifikation",
      "type": "metering",
      "params": {
        "metrics": ["lufs_integrated", "lufs_short_term", "true_peak", "dynamic_range_dr"],
        "tools": ["youlean_loudness_meter", "izotope_insight_2", "waves_wlm_plus"]
      },
      "purpose": "Mess gegen Plattform-Targets vor Final-Export.",
      "optional": false
    }
  ],

