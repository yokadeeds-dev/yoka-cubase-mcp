      "target_lufs_integrated": -14,
      "true_peak_db": -1,
      "normalization": "on_default",
      "notes": "Lautere Tracks werden runter normalisiert; verlieren Dynamik. Optimal: Master nahe -14 LUFS, Dynamik bewahren."
    },
    "apple_music": {
      "display_name": "Apple Music",
      "target_lufs_integrated": -16,
      "true_peak_db": -1,
      "normalization": "on_sound_check",
      "notes": "Sound Check standardmäßig aktiv. Ziel niedriger als Spotify — mehr Dynamik-Reserve."
    },
    "youtube": {
      "display_name": "YouTube / YouTube Music",
      "target_lufs_integrated": -14,
      "true_peak_db": -1,
      "normalization": "on",
      "notes": "Normalisierung auf -14 LUFS, lautere Tracks werden runtergeregelt."
    },
    "tidal": {
      "display_name": "Tidal",
      "target_lufs_integrated": -14,
      "true_peak_db": -1,
      "normalization": "on",
      "notes": "Vergleichbar Spotify. HiFi/Master-Tier nutzt Original-Master."
    },
    "soundcloud": {
      "display_name": "SoundCloud",
      "target_lufs_integrated": -10,
      "true_peak_db": -0.3,
      "normalization": "off",
